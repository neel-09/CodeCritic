# ── LLM Providers ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=                        # Gemini API key (platform.ai.google.dev)
GROQ_API_KEY=                          # Groq API key (console.groq.com) — fallback LLM

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=                          # https://your-project.supabase.co
SUPABASE_SERVICE_KEY=                  # service_role key (not anon key)

# ── Wokwi ─────────────────────────────────────────────────────────────────────
WOKWI_CLI_TOKEN=                       # from wokwi.com/dashboard
WOKWI_CLI_PATH=                        # full path to wokwi-cli executable
WOKWI_MONTHLY_BUDGET_SECONDS=3600      # simulation budget in seconds per month

# ── Arduino ───────────────────────────────────────────────────────────────────
ARDUINO_DATA_DIR=                      # directory for arduino-cli packages and libraries
HEX_CACHE_DIR=                         # directory to store compiled .hex files

# ── LangSmith Tracing (optional) ──────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=codecritic
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://apac.api.smith.langchain.com

# ── Tavily ────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=                        # tavily.com — component datasheet search